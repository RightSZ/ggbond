library(ggplot2)
p1 <- ggplot(mtcars, aes(wt, mpg)) + geom_point()
p2 <- ggplot(mtcars, aes(factor(cyl), mpg)) + geom_boxplot()
devtools::load_all()
run_ggbond(
plot_list = list(
A = p1,
B = p2
)
)
p1
